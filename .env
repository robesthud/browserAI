# Database URL for PostgreSQL (used by Docker Compose)
DATABASE_URL="postgresql://aicode:supersecret@postgres:5432/aicode"

# Database URL for SQLite (uncomment for running purely locally without Docker)
# DATABASE_URL="file:./prisma/dev.db"

# Redis URL
REDIS_URL="redis://redis:6379"
# REDIS_URL="redis://localhost:6379" # (for running purely locally without Docker)

# Authentication
JWT_SECRET="your-super-secret-jwt-key-change-this"

# GitHub OAuth (https://github.com/settings/developers)
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"

# AI Providers API Keys
OPENAI_API_KEY="sk-..."
ANTHROPIC_API_KEY="sk-ant-..."
GOOGLE_AI_API_KEY="AIzaSy..."
GROQ_API_KEY="gsk_..."
DEEPSEEK_API_KEY="sk-..."
MISTRAL_API_KEY="..."
QWEN_API_KEY="sk-..."

# Local AI Models URLs
OLLAMA_URL="http://localhost:11434"
LMSTUDIO_URL="http://localhost:1234"

# Microservices URLs
CODE_RUNNER_URL="http://code-runner:8000"
# CODE_RUNNER_URL="http://localhost:8000" # (for running purely locally without Docker)

BROWSER_AI_URL="http://browser-agent:8080"
# BROWSER_AI_URL="http://localhost:8080" # (for running purely locally without Docker)

COLLABORATION_URL="http://collaboration:3001"
# COLLABORATION_URL="http://localhost:3001" # (for running purely locally without Docker)

# Frontend configuration
FRONTEND_URL="http://localhost"
PORT=3000
HOST="0.0.0.0"
