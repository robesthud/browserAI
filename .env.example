# ============================================
# AI CODE STUDIO - ENVIRONMENT CONFIGURATION
# Copy to .env and customize values
# ============================================

# Database URLs (Default points to PostgreSQL in Docker Compose)
DATABASE_URL="postgresql://aicode:supersecret@localhost:5432/aicode"

# Redis Cache URL
REDIS_URL="redis://localhost:6379"

# Core service credentials
JWT_SECRET="change-this-super-secret-key-in-production-deployments"
ENCRYPTION_KEY="637172737475767778797a6162636465666768696a6b6c6d6e6o7p7q7r7s7t7u" # 32-byte hex key for API Key DB Encryption

# Demo Mode (If true, starts backend on SQLite and mocks some services if unconfigured)
DEMO_MODE=true

# Google / GitHub Auth Credentials
GITHUB_CLIENT_ID="your_github_client_id"
GITHUB_CLIENT_SECRET="your_github_client_secret"
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"

# S3 Object Storage Configuration (MinIO falling back to local files)
S3_ENDPOINT="http://localhost:9000"
S3_BUCKET="aicode-blobs"
S3_REGION="us-east-1"
S3_ACCESS_KEY_ID="minioadmin"
S3_SECRET_ACCESS_KEY="minioadmin"

# AI Provider API Keys
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GOOGLE_AI_API_KEY=""
GROQ_API_KEY=""
DEEPSEEK_API_KEY=""
MISTRAL_API_KEY=""
QWEN_API_KEY=""

# Local LLM Servers
OLLAMA_URL="http://localhost:11434"
LMSTUDIO_URL="http://localhost:1234"

# Container Network Microservice bindings
CODE_RUNNER_URL="http://localhost:8000"
BROWSER_AI_URL="http://localhost:8080"
COLLABORATION_URL="http://localhost:3001"

# Frontend settings
FRONTEND_URL="http://localhost:5173"
PORT=3000
HOST="0.0.0.0"
