# BrowserAI environment example.
# Copy to .env and adjust values; docker-compose picks them up automatically.

# ── App ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=8080
APP_URL=http://your.domain.example
SESSION_SECRET=replace-with-a-long-random-string
# AUTH_SECRET is what the server ACTUALLY uses to derive the AES-256-GCM key
# for encrypted cloud sync (HKDF). Without it a known dev default is used —
# never run production without setting this. Generate with:
#   openssl rand -base64 48
AUTH_SECRET=replace-with-another-long-random-string

# ── CORS (optional) ─────────────────────────────────────────────────────────
# Extra allowed origin besides APP_URL (e.g. raw-IP access during setup).
# CORS_ORIGIN=http://203.0.113.10

# ── Persisted state (bind-mounts on the host) ──────────────────────────────
# Defaults to ./data and ./workspace next to docker-compose.yml.
# Use absolute paths in production so `docker compose down -v`, image
# rebuilds, or repo re-clones never touch the session/db files.
DATA_DIR=/opt/browserai-data
WORKSPACE_DIR=/opt/browserai-workspace
# Path inside the container used by both API and agent sandbox.
WORKSPACE_ROOT=/workspace

# ── Gemini Web Proxy (used by the Free Gateway) ────────────────────────────
# The gateway routes gemini-2.5-* / gemini-2.0-flash to this proxy.
# Default assumes browserai runs inside docker-compose and the proxy is on the
# host at port 8080. Override if the proxy is on a different host/port.
# If GEMINI_WEB_PROXY_TOKEN is set (and != 'not-needed'), it is sent as
# `Authorization: Bearer ...` AND as `X-Proxy-Token: ...` to the proxy.
# GEMINI_WEB_PROXY_URL=http://host.docker.internal:8080/v1
# GEMINI_WEB_PROXY_TOKEN=not-needed

# ── DeepSeek managed session (optional) ────────────────────────────────────
# These bootstrap the refresher on first start. After that, state is stored
# in /data/deepseek_session.json and the values can be edited from the
# admin panel (/admin/deepseek) or Telegram bot — no restart needed.
# DEEPSEEK_USER_TOKEN=eyJhbGciOi...
# DEEPSEEK_COOKIES=cf_clearance=...; ds_session_id=...; smidV2=...
# DEEPSEEK_HEARTBEAT_MS=600000          # 10 min
# DEEPSEEK_MODELS_REFRESH_MS=3600000    # 1 h
# TELEGRAM_BOT=off                      # to disable Telegram v2 bot

# ── LLM provider API keys (optional) ───────────────────────────────────────
# GEMINI_API_KEY=          # https://aistudio.google.com/apikey (free tier)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# BROWSERAI_DAILY_USD=5    # per-user daily LLM spend cap (USD)
# Agent autopilot routing/safety toggles.
# BROWSERAI_LIGHTWEIGHT_ROUTE=0                 # 0 = full agent loop for all turns
# BROWSERAI_DISABLE_CATASTROPHIC_APPROVAL=0     # set 1 only for trusted disposable/owner-only deployments

# ── Telegram bots (optional) ───────────────────────────────────────────────
# Single Telegram v2 bot token from @BotFather; chat_id of the admin who can issue commands.
# The same bot provides admin menu, server logs/health/CI/deploy and AI agent chat.
TG_BOT_TOKEN=
TG_ADMIN_CHAT_ID=
# TELEGRAM_BOT=off

# ── GitHub integration (optional) ──────────────────────────────────────────
# GITHUB_TOKEN=
# GITHUB_REPO=owner/repo

# ── SMS / Twilio (optional, used for phone-OTP signup) ────────────────────
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM=
