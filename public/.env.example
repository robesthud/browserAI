# ============================================
# AI CODE STUDIO - ENVIRONMENT VARIABLES
# Copy to .env and fill in your values
# ============================================

# ============================================
# DATABASE
# ============================================
POSTGRES_PASSWORD=supersecret
DATABASE_URL=postgresql://aicode:supersecret@postgres:5432/aicode

# ============================================
# REDIS
# ============================================
REDIS_URL=redis://redis:6379

# ============================================
# AUTHENTICATION
# ============================================
JWT_SECRET=your-super-secret-jwt-key-change-this

# GitHub OAuth (https://github.com/settings/developers)
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# ============================================
# AI PROVIDERS (add keys for providers you use)
# ============================================

# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-...

# Anthropic (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=sk-ant-...

# Google AI (https://aistudio.google.com/app/apikey)
GOOGLE_AI_API_KEY=AIzaSy...

# Groq (https://console.groq.com/keys)
GROQ_API_KEY=gsk_...

# DeepSeek (https://platform.deepseek.com/api_keys)
DEEPSEEK_API_KEY=sk-...

# Mistral (https://console.mistral.ai/api-keys/)
MISTRAL_API_KEY=...

# Qwen/Alibaba (https://dashscope.console.aliyun.com/)
QWEN_API_KEY=sk-...

# ============================================
# LOCAL AI (Ollama / LM Studio)
# ============================================
OLLAMA_URL=http://localhost:11434
LMSTUDIO_URL=http://localhost:1234

# ============================================
# SERVICES
# ============================================
CODE_RUNNER_URL=http://code-runner:8000
BROWSER_AI_URL=http://browser-agent:8080
COLLABORATION_URL=http://collaboration:3001

# ============================================
# FRONTEND
# ============================================
FRONTEND_URL=http://localhost
