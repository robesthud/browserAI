{
  "name": "browserai",
  "private": true,
  "version": "1.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "server": "node server/index.js",
    "dev:all": "concurrently -n web,api -c cyan,green \"vite\" \"node server/index.js\"",
    "start": "node server/index.js",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run --no-file-parallelism --passWithNoTests",
    "agent": "node ./bin/browserai-agent.js",
    "agent:jsonl": "node ./bin/browserai-agent.js --jsonl"
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "^0.80.2",
    "@earendil-works/pi-ai": "^0.80.2",
    "adm-zip": "^0.5.16",
    "better-sqlite3": "^12.10.0",
    "cheerio": "^1.2.0",
    "cors": "^2.8.6",
    "docx": "^9.7.1",
    "dompurify": "^3.4.11",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "ipaddr.js": "^2.2.0",
    "is-ip": "^5.0.1",
    "nodemailer": "^9.0.1",
    "pdfkit": "^0.19.0",
    "playwright-core": "^1.60.0",
    "pptxgenjs": "^4.0.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tar": "^7.5.16",
    "typebox": "^1.1.38",
    "undici": "^7.28.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-legacy": "^8.0.2",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "postcss": "^8.5.15",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.4.19",
    "terser": "^5.48.0",
    "vite": "^8.0.12",
    "vitest": "^4.1.8"
