<?xml version="1.0" encoding="utf-8"?>
<!--
    Network Security Config — разрешаем только HTTPS для production.
    Cleartext (HTTP) запрещён кроме localhost (для локальной разработки через Termux).
-->
<network-security-config>
    <!-- Production Railway — только HTTPS -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">up.railway.app</domain>
        <domain includeSubdomains="true">railway.app</domain>
    </domain-config>

    <!-- Локальная разработка — разрешаем HTTP для localhost/Termux -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
        <domain includeSubdomains="false">10.0.2.2</domain>
    </domain-config>

    <!-- Всё остальное — HTTPS обязательно -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
