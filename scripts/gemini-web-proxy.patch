+            await asyncio.sleep(5)
+            return
+    except Exception as e:
+        last_error = e
+
+    if await try_inputs():
+        return
+
+    debug = await page.evaluate('''() => [...document.querySelectorAll('input[type="file"], button[xapfileselectortrigger], [role="menuitem"], button')].map((el,i)=>{
+      const r=el.getBoundingClientRect();
+      return {i, tag:el.tagName, visible:!!(r.width&&r.height), rect:{x:r.x,y:r.y,w:r.width,h:r.height}, aria:el.getAttribute('aria-label')||'', role:el.getAttribute('role')||'', cls:el.className||'', test:el.getAttribute('data-test-id')||'', text:(el.textContent||'').replace(/\s+/g,' ').trim().slice(0,100), html:(el.outerHTML||'').replace(/\s+/g,' ').trim().slice(0,200)}
+    }).slice(0,140)''')
+    raise Exception('Could not attach image files to Gemini UI: ' + str(last_error) + ' debug=' + json.dumps(debug, ensure_ascii=False)[:2500])
+
