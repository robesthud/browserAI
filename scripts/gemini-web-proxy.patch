+def extract_image_urls(content: Any) -> List[str]:
+    """Extract OpenAI-compatible image_url/file_url data URLs from message content."""
+    urls = []
+    if isinstance(content, list):
+        for c in content:
+            if not isinstance(c, dict):
+                continue
+            url = None
+            if c.get("type") == "image_url":
+                image_url = c.get("image_url")
+                url = image_url.get("url") if isinstance(image_url, dict) else image_url
+            elif c.get("type") in ("file_url", "file"):
+                file_url = c.get("file_url") or c.get("file")
+                url = file_url.get("url") if isinstance(file_url, dict) else file_url
+            if isinstance(url, str) and url.startswith('data:'):
+                urls.append(url)
+    return urls
+
+
+def data_url_to_temp_file(data_url: str) -> Optional[str]:
+    m = re.match(r'^data:([^;,]+)(?:;[^,]*)?,(.*)$', data_url or '', re.S)
+    if not m:
+        return None
+    mime, payload = m.group(1), m.group(2)
+    ext = 'bin'
+    if 'png' in mime: ext = 'png'
+    elif 'jpeg' in mime or 'jpg' in mime: ext = 'jpg'
+    elif 'webp' in mime: ext = 'webp'
+    elif 'gif' in mime: ext = 'gif'
+    elif 'pdf' in mime: ext = 'pdf'
+    elif 'wordprocessingml' in mime: ext = 'docx'
+    elif 'presentationml' in mime or 'powerpoint' in mime: ext = 'pptx'
+    elif 'spreadsheetml' in mime or 'excel' in mime: ext = 'xlsx'
+    elif 'csv' in mime: ext = 'csv'
+    elif 'mp4' in mime: ext = 'mp4'
+    elif 'quicktime' in mime: ext = 'mov'
+    elif 'webm' in mime: ext = 'webm'
+    elif 'mpeg' in mime: ext = 'mp3'
+    elif 'wav' in mime: ext = 'wav'
+    elif 'ogg' in mime: ext = 'ogg'
+    elif 'flac' in mime: ext = 'flac'
+    elif 'zip' in mime: ext = 'zip'
+    elif 'text/plain' in mime: ext = 'txt'
+    try:
+        raw = base64.b64decode(payload)
+    except Exception:
+        return None
+    fd, path = tempfile.mkstemp(prefix='gemini-upload-', suffix='.' + ext)
+    with os.fdopen(fd, 'wb') as f:
+        f.write(raw)
+    return path
+
+
