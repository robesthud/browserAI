+            try:
+                await inp.set_input_files(image_paths)
+                await asyncio.sleep(4)
+                return True
+            except Exception:
+                continue
+        return False
+
+    if await try_inputs():
+        return
+
+    # Open upload/tools menu via plus button near composer.
+    btn = await page.query_selector('button[aria-label="Загрузка и инструменты"]') \
+        or await page.query_selector('button[aria-label="Upload and tools"]') \
+        or await page.query_selector('button[aria-haspopup="menu"][aria-label*="Загрузка" i]') \
+        or await page.query_selector('button[aria-haspopup="menu"][aria-label*="Upload" i]')
+    if not btn:
+        raise Exception('Gemini upload/tools button not found')
+    await btn.click()
+    await asyncio.sleep(1.2)
+
+    # Gemini uses hidden xapfileselectortrigger buttons that open file chooser.
+    chooser_selectors = [
+        'button.hidden-local-file-image-selector-button',
+        'button[data-test-id="hidden-local-image-upload-button"]',
+        'button.hidden-local-file-upload-button',
+        'button[data-test-id="hidden-local-file-upload-button"]',
+        'button[xapfileselectortrigger]',
+    ]
+    last_error = None
+    for sel in chooser_selectors:
+        try:
+            el = await page.query_selector(sel)
+            if not el:
+                continue
+            async with page.expect_file_chooser(timeout=5000) as fc_info:
+                try:
+                    await el.click(force=True)
+                except Exception:
+                    await page.evaluate('(e) => e.click()', el)
+            chooser = await fc_info.value
+            await chooser.set_files(image_paths)
+            await asyncio.sleep(5)
+            return
+        except Exception as e:
+            last_error = e
+            continue
+
+    # Fallback: click visible "Загрузить файлы" menu item and catch chooser.
+    try:
+        item = await page.query_selector('[role="menuitem"]:has-text("Загрузить файлы")') \
